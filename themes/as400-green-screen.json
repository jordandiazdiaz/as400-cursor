{
  "name": "AS/400 Green Screen (5250)",
  "type": "dark",
  "colors": {
    "editor.background": "#000000",
    "editor.foreground": "#00FF00",
    "editorCursor.foreground": "#00FF00",
    "editorCursor.background": "#000000",
    "editor.selectionBackground": "#005500",
    "editor.selectionForeground": "#00FF00",
    "editor.lineHighlightBackground": "#001a00",
    "editor.lineHighlightBorder": "#003300",
    "editorLineNumber.foreground": "#007700",
    "editorLineNumber.activeForeground": "#00FF00",
    "editorIndentGuide.background1": "#003300",
    "editorIndentGuide.activeBackground1": "#005500",
    "editorWhitespace.foreground": "#003300",
    "editorBracketMatch.background": "#004400",
    "editorBracketMatch.border": "#00FF00",
    "editorGroupHeader.tabsBackground": "#000000",
    "editorGroupHeader.tabsBorder": "#003300",
    "tab.activeBackground": "#001a00",
    "tab.activeForeground": "#00FF00",
    "tab.inactiveBackground": "#000000",
    "tab.inactiveForeground": "#007700",
    "tab.border": "#003300",
    "activityBar.background": "#000000",
    "activityBar.foreground": "#00FF00",
    "activityBar.border": "#003300",
    "sideBar.background": "#000000",
    "sideBar.foreground": "#00CC00",
    "sideBar.border": "#003300",
    "sideBarTitle.foreground": "#00FF00",
    "sideBarSectionHeader.background": "#001a00",
    "sideBarSectionHeader.foreground": "#00FF00",
    "statusBar.background": "#001a00",
    "statusBar.foreground": "#00FF00",
    "statusBar.border": "#003300",
    "titleBar.activeBackground": "#000000",
    "titleBar.activeForeground": "#00FF00",
    "titleBar.inactiveBackground": "#000000",
    "titleBar.inactiveForeground": "#007700",
    "input.background": "#001100",
    "input.foreground": "#00FF00",
    "input.border": "#005500",
    "input.placeholderForeground": "#005500",
    "dropdown.background": "#001100",
    "dropdown.foreground": "#00FF00",
    "dropdown.border": "#005500",
    "list.activeSelectionBackground": "#003300",
    "list.activeSelectionForeground": "#00FF00",
    "list.hoverBackground": "#001a00",
    "list.hoverForeground": "#00FF00",
    "list.focusBackground": "#003300",
    "list.focusForeground": "#00FF00",
    "terminal.background": "#000000",
    "terminal.foreground": "#00FF00",
    "terminal.ansiGreen": "#00FF00",
    "terminal.ansiBlack": "#000000",
    "terminal.ansiBrightGreen": "#33FF33",
    "panel.background": "#000000",
    "panel.border": "#003300",
    "panelTitle.activeForeground": "#00FF00",
    "panelTitle.inactiveForeground": "#007700",
    "panelTitle.activeBorder": "#00FF00",
    "badge.background": "#005500",
    "badge.foreground": "#00FF00",
    "scrollbar.shadow": "#000000",
    "scrollbarSlider.background": "#005500aa",
    "scrollbarSlider.hoverBackground": "#007700aa",
    "scrollbarSlider.activeBackground": "#00aa00aa",
    "minimap.background": "#000000",
    "focusBorder": "#00AA00",
    "foreground": "#00CC00",
    "widget.shadow": "#000000",
    "selection.background": "#005500",
    "descriptionForeground": "#009900",
    "errorForeground": "#FF5555",
    "icon.foreground": "#00CC00"
  },
  "tokenColors": [
    {
      "scope": "",
      "settings": {
        "foreground": "#00FF00"
      }
    },
    {
      "name": "Comments",
      "scope": ["comment", "punctuation.definition.comment"],
      "settings": {
        "foreground": "#007700",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": ["string", "string.quoted"],
      "settings": {
        "foreground": "#33FF99"
      }
    },
    {
      "name": "Keywords",
      "scope": ["keyword", "storage.type", "storage.modifier"],
      "settings": {
        "foreground": "#00FFAA",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": ["entity.name.function", "support.function"],
      "settings": {
        "foreground": "#66FF66"
      }
    },
    {
      "name": "Types",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#00FFCC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Variables",
      "scope": ["variable", "variable.other"],
      "settings": {
        "foreground": "#00EE00"
      }
    },
    {
      "name": "Numbers",
      "scope": ["constant.numeric"],
      "settings": {
        "foreground": "#99FF99"
      }
    },
    {
      "name": "Constants",
      "scope": ["constant", "constant.language"],
      "settings": {
        "foreground": "#00FFDD"
      }
    },
    {
      "name": "Operators",
      "scope": ["keyword.operator"],
      "settings": {
        "foreground": "#00DD00"
      }
    },
    {
      "name": "Punctuation",
      "scope": ["punctuation"],
      "settings": {
        "foreground": "#00BB00"
      }
    },
    {
      "name": "Tags (HTML/XML)",
      "scope": ["entity.name.tag"],
      "settings": {
        "foreground": "#00FF88"
      }
    },
    {
      "name": "Attributes",
      "scope": ["entity.other.attribute-name"],
      "settings": {
        "foreground": "#66FFAA"
      }
    },
    {
      "name": "Invalid / Errors",
      "scope": ["invalid", "invalid.illegal"],
      "settings": {
        "foreground": "#FF4444",
        "fontStyle": "underline"
      }
    }
  ]
}
